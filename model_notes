def _half_life(path, peak_t):
    peak_val = abs(path[peak_t])
    if peak_val < 1e-12:
        return 0
    for t in range(peak_t + 1, len(path)):
        if abs(path[t]) < 0.5 * peak_val:
            return t - peak_t
    return len(path) - peak_t

